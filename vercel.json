{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://cancercarebaskets.org https://*.cancercarebaskets.org https://*.netlify.app https://*.vercel.app"
        }
      ]
    }
  ]
}
