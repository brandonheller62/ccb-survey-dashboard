# Google Sheets connection (server-side only — never exposed to the browser).
# Copy this file to .env.local for local dev, and set the same vars in
# Vercel → Settings → Environment Variables for production.
#
# If these are left blank, the dashboard falls back to public/sample-survey.csv
# so you can explore the UI before connecting a real Sheet.

# The service account's email (from the JSON key: "client_email").
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The service account's private key (from the JSON key: "private_key").
# Keep the surrounding quotes; the \n escapes are handled automatically.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The Sheet id — the long token in the URL: docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEET_ID=

# The tab + range to read. Google Forms responses live on "Form Responses 1" by default.
GOOGLE_SHEET_RANGE=Form Responses 1
